{
  "expo": {
    "name": "Outboard Brain",
    "slug": "outboard-brain",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/brain.png",
    "scheme": "outboardbrain",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "isTabletOnly": true,
      "bundleIdentifier": "com.outboardbrain.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "75f65e8d-50c4-4a83-8748-4f54c30dcc68"
      }
    },
    "owner": "mmadsensji",
    "android": {
      "package": "com.outboardbrain.app"
    }
  }
}
